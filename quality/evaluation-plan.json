{
  "schema_version": 1,
  "intended_use": "News-intelligence monitoring for analyst review, prioritization, provenance tracing, and configurable alert routing.",
  "prohibited_uses": [
    "fully automated adverse decisions about people",
    "unreviewed publication of sensitive allegations as verified fact",
    "law-enforcement, employment, credit, housing, insurance, or medical eligibility decisions",
    "identity verification or biometric inference"
  ],
  "risk_levels": {
    "low": "public organization/entity monitoring with source-visible evidence",
    "medium": "claims about market, operational, or regulatory events",
    "high": "claims involving alleged wrongdoing, safety incidents, sensitive personal attributes, or high-severity external notification"
  },
  "critical_stages": {
    "extraction": {
      "metrics": {"precision": 0.9, "recall": 0.75, "evidence_span_accuracy": 0.9},
      "regression_budget": {"precision_drop": 0.03, "recall_drop": 0.05}
    },
    "entity_resolution": {
      "metrics": {"precision": 0.95, "recall": 0.8, "review_routing_recall": 0.98},
      "regression_budget": {"precision_drop": 0.02, "review_routing_recall_drop": 0.01}
    },
    "claim_linking": {
      "metrics": {"precision": 0.88, "recall": 0.7, "contradiction_precision": 0.85},
      "regression_budget": {"precision_drop": 0.03, "contradiction_precision_drop": 0.03}
    },
    "alert_quality": {
      "metrics": {"precision_at_review": 0.8, "suppression_precision": 0.9, "routing_accuracy": 0.9},
      "regression_budget": {"precision_at_review_drop": 0.05, "routing_accuracy_drop": 0.03}
    }
  },
  "human_review_rules": [
    {
      "rule": "sensitive_high_impact_claim",
      "condition": "risk_level == high",
      "action": "require_human_review_before_verified_label_or_external_notification"
    },
    {
      "rule": "low_confidence_entity_resolution",
      "condition": "entity_resolution.confidence < 0.85 or alternatives > 1",
      "action": "abstain_from_model_verified_status_and_route_to_review"
    },
    {
      "rule": "low_confidence_claim_extraction",
      "condition": "claim.confidence < 0.8",
      "action": "do_not_trigger_high_severity_alert_without corroborating evidence"
    }
  ],
  "monitoring": {
    "quality_proxies": [
      "alert_relevance_feedback_rate",
      "alert_false_positive_rate_by_source",
      "entity_resolution_review_rate",
      "claim_dispute_rate",
      "source_language_distribution_drift",
      "suppressed_high_score_alert_count"
    ],
    "rollback_criteria": [
      "critical-stage metric below threshold on release candidate",
      "precision regression exceeds configured budget",
      "high-risk review-routing recall below threshold",
      "production feedback indicates sustained false-positive rate above approved budget"
    ]
  },
  "external_blockers": [
    "representative licensed evaluation data",
    "independent annotation review",
    "release-candidate evaluation report",
    "business/legal approval of false-positive and false-negative budgets"
  ]
}
