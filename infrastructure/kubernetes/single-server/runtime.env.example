# Copy this file outside the repository, replace every placeholder with a unique
# generated value, set mode 0600, and create the Kubernetes Secret from it.
POSTGRES_DB=signalchord
POSTGRES_USER=signalchord
POSTGRES_PASSWORD=<generate-unique-value>
DATABASE_URL=postgresql://signalchord:<same-postgres-password>@postgres:5432/signalchord
SECRET_KEY_BASE=<generate-at-least-64-random-hex-bytes>
CONTROL_PLANE_INTERNAL_TOKEN=<generate-at-least-32-random-hex-bytes>
NOTIFICATION_TOKEN_ENCRYPTION_KEY=<generate-at-least-32-random-hex-bytes>
NEO4J_USER=neo4j
NEO4J_PASSWORD=<generate-unique-value>
NEO4J_AUTH=neo4j/<same-neo4j-password>
MINIO_ACCESS_KEY=<generate-unique-access-key>
MINIO_SECRET_KEY=<generate-at-least-32-random-hex-bytes>
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<generate-unique-value>
