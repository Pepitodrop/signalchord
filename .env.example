# Local-development example only. Never reuse these values in staging or production.
SIGNALCHORD_ENV=development
SIGNALCHORD_TENANT_ID=tenant-demo
KAFKA_BROKERS=kafka:9092
POSTGRES_URL=postgresql://signalchord:signalchord@postgres:5432/signalchord
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=signalchord-dev
# Valkey is Redis-protocol compatible, so existing clients keep using REDIS_URL.
REDIS_URL=redis://valkey:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=signalchord
MINIO_SECRET_KEY=signalchord-dev-secret
MINIO_BUCKET=raw-documents
OPENSEARCH_URL=http://opensearch:9200
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
JWT_DEVELOPMENT_SECRET=replace-me
# cors.rb reads WEB_ORIGINS (plural, comma-separated) — this was previously
# WEB_ORIGIN (singular) here, which never matched what CORS actually reads.
# docker-compose.override.yml already sets the plural correctly; this was a
# documentation-only mismatch, fixed alongside the closed-beta onboarding CORS
# change (adding credentials: true to the same initializer).
WEB_ORIGINS=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000/api/v1
REALTIME_URL=http://localhost:8088/events

# --- Closed-beta onboarding ---
BETA_ACCESS_CODE=replace-me-with-a-real-shared-secret
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
SESSION_COOKIE_NAME=sc_session
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_STARTTLS=false
SMTP_OPEN_TIMEOUT=5
SMTP_READ_TIMEOUT=5
MAILER_FROM_ADDRESS=beta@signalchord.example
PUBLIC_WEB_URL=http://localhost:5173
SIGNUP_RATE_LIMIT=10
EMAIL_VERIFICATION_RATE_LIMIT=20
EMAIL_VERIFICATION_RESEND_RATE_LIMIT=5
